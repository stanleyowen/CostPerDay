    "Tap the value to select it directly, or use the stepper to adjust one month at a time." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippen Sie auf den Wert, um ihn direkt auszuwählen, oder verwenden Sie den Schrittregler, um ihn monatsweise anzupassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the value to select it directly, or use the stepper to adjust one month at a time."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque el valor para seleccionarlo directamente o utilice el control de pasos para ajustarlo mes a mes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez la valeur pour la sélectionner directement, ou utilisez le sélecteur pour l'ajuster mois par mois."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ketuk nilainya untuk memilih secara langsung, atau gunakan tombol penyesuai untuk mengubah satu bulan setiap kali."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "数値をタップすると直接選択でき、ステッパーを使うと1か月単位で調整できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "값을 탭하면 직접 선택할 수 있고, 스테퍼를 사용하면 한 달 단위로 조정할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
