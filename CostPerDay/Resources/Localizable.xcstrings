    "Retiring an item stops its cost calculation while retaining it in your history and statistics." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie einen Artikel außer Dienst stellen, wird dessen Kostenberechnung beendet, er bleibt jedoch in Ihrem Verlauf und Ihren Statistiken erhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retiring an item stops its cost calculation while retaining it in your history and statistics."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retirar un artículo detiene el cálculo de su costo y lo conserva en su historial y sus estadísticas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retirer un article du service interrompt le calcul de son coût tout en le conservant dans votre historique et vos statistiques."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menonaktifkan suatu barang akan menghentikan perhitungan biayanya, sementara barang tersebut tetap tersimpan dalam riwayat dan statistik Anda."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "項目を使用終了にすると、コストの計算は停止しますが、履歴と統計には引き続き含まれます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "항목을 사용 종료로 표시하면 비용 계산은 중단되지만 기록과 통계에는 그대로 남습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desativar um item interrompe o cálculo do seu custo, mantendo-o no seu histórico e nas suas estatísticas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вывод предмета из эксплуатации останавливает расчёт его стоимости, но сохраняет его в истории и статистике."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Việc ngừng sử dụng một món đồ sẽ dừng tính chi phí của món đồ đó, đồng thời vẫn giữ lại nó trong lịch sử và thống kê của bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "停用物品后将停止计算其成本，但仍会保留在您的历史记录与统计之中。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "停用物品後將停止計算其成本，但仍會保留於您的歷史紀錄與統計之中。"
          }
        }
      }
    },
