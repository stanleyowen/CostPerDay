    "Pre-fills the expected lifetime when this category is selected. It can still be adjusted for each individual item." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Füllt die erwartete Nutzungsdauer vor, wenn diese Kategorie ausgewählt wird. Sie kann für jeden einzelnen Artikel weiterhin angepasst werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pre-fills the expected lifetime when this category is selected. It can still be adjusted for each individual item."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rellena previamente la vida útil prevista al seleccionar esta categoría. Puede ajustarse en cada artículo por separado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pré-remplit la durée de vie prévue lorsque cette catégorie est sélectionnée. Elle reste modifiable pour chaque article."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mengisi masa pakai yang diharapkan secara otomatis ketika kategori ini dipilih. Nilai tersebut tetap dapat disesuaikan untuk setiap barang."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このカテゴリを選択したときに、想定使用期間があらかじめ入力されます。個々の項目ごとに変更することもできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 카테고리를 선택하면 예상 사용 기간이 미리 입력됩니다. 항목별로 다시 조정할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Preenche previamente a vida útil prevista quando esta categoria é selecionada. Ela ainda pode ser ajustada em cada item."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подставляет ожидаемый срок службы при выборе этой категории. Его можно изменить для каждого отдельного предмета."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tự động điền tuổi thọ dự kiến khi danh mục này được chọn. Giá trị đó vẫn có thể được điều chỉnh cho từng món đồ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择此类别时会自动填入预期使用年限，仍可针对单件物品进行调整。"
