    "Record a few items and your spending will be summarised here." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfassen Sie einige Artikel, dann werden Ihre Ausgaben hier zusammengefasst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Record a few items and your spending will be summarised here."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registre algunos artículos y su gasto se resumirá aquí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistrez quelques articles et vos dépenses seront résumées ici."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Catat beberapa barang dan ringkasan pengeluaran Anda akan ditampilkan di sini."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "項目をいくつか記録すると、支出の概要がここに表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "항목을 몇 개 기록하면 지출 요약이 여기에 표시됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registre alguns itens e os seus gastos serão resumidos aqui."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавьте несколько предметов, и здесь появится сводка ваших расходов."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hãy ghi nhận một vài món đồ và chi tiêu của bạn sẽ được tổng hợp tại đây."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "记录若干件物品后，您的支出将汇总于此。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "記錄幾件物品後，您的支出將彙整於此。"
          }
        }
      }
    },
    "Record the items you own — electronics, furniture, appliances, clothing — to see what each one costs you per day." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfassen Sie Ihren Besitz — Elektronik, Möbel, Haushaltsgeräte, Kleidung —, um zu sehen, was Sie jeder einzelne Artikel pro Tag kostet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Record the items you own — electronics, furniture, appliances, clothing — to see what each one costs you per day."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registre los artículos que posee (electrónica, mobiliario, electrodomésticos, ropa) para ver cuánto le cuesta cada uno al día."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistrez les biens que vous possédez — électronique, mobilier, électroménager, vêtements — pour voir ce que chacun vous coûte par jour."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Catat barang-barang yang Anda miliki — elektronik, perabot, peralatan rumah tangga, pakaian — untuk melihat berapa biaya masing-masing barang per hari."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有している物（電子機器、家具、家電、衣類など）を記録すると、それぞれの1日あたりのコストを確認できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "보유한 물품(전자기기, 가구, 가전, 의류 등)을 기록하면 각 물품의 하루 비용을 확인할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registre os itens que você possui (eletrônicos, móveis, eletrodomésticos, roupas) para ver quanto cada um custa por dia."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Записывайте принадлежащие вам вещи — электронику, мебель, технику, одежду, — чтобы видеть, во сколько каждая из них обходится вам в день."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hãy ghi nhận những món đồ bạn sở hữu — đồ điện tử, nội thất, thiết bị gia dụng, quần áo — để biết mỗi món tiêu tốn bao nhiêu mỗi ngày."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "记录您拥有的物品 — 电子产品、家具、家电、服装 — 即可了解每一件每天的花费。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "記錄您擁有的物品 — 電子產品、家具、家電、服裝 — 即可了解每一件每天的花費。"
          }
        }
      }
    },
