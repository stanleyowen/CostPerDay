          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Коснитесь значения, чтобы выбрать его напрямую, или используйте шаговый регулятор для изменения на один месяц."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chạm vào giá trị để chọn trực tiếp, hoặc dùng nút tăng giảm để điều chỉnh từng tháng một."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
