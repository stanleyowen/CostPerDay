    "Your %lld items are currently priced against %@. This rate re-expresses them in %@. The prices originally entered remain unchanged; only the conversion is adjusted." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "variations" : {
            "plural" : {
              "one" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Ihr %1$lld Artikel ist derzeit in %2$@ bewertet. Dieser Kurs rechnet ihn in %3$@ um. Die ursprünglich eingegebenen Preise bleiben unverändert; nur die Umrechnung wird angepasst."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Ihre %1$lld Artikel sind derzeit in %2$@ bewertet. Dieser Kurs rechnet sie in %3$@ um. Die ursprünglich eingegebenen Preise bleiben unverändert; nur die Umrechnung wird angepasst."
                }
              }
            }
          }
        },
        "en" : {
          "variations" : {
            "plural" : {
              "one" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Your %lld item is currently priced against %@. This rate re-expresses it in %@. The price originally entered remains unchanged; only the conversion is adjusted."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Your %lld items are currently priced against %@. This rate re-expresses them in %@. The prices originally entered remain unchanged; only the conversion is adjusted."
                }
              }
            }
          }
        },
        "es" : {
          "variations" : {
            "plural" : {
              "one" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Su %lld artículo está valorado actualmente en %@. Esta tasa lo reexpresa en %@. Los precios introducidos originalmente no se modifican; solo se ajusta la conversión."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Sus %lld artículos están valorados actualmente en %@. Esta tasa los reexpresa en %@. Los precios introducidos originalmente no se modifican; solo se ajusta la conversión."
                }
              }
            }
          }
        },
        "fr" : {
          "variations" : {
            "plural" : {
              "one" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Votre %lld article est actuellement valorisé en %@. Ce taux le convertit en %@. Les prix saisis à l'origine restent inchangés ; seule la conversion est ajustée."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Vos %lld articles sont actuellement valorisés en %@. Ce taux les convertit en %@. Les prix saisis à l'origine restent inchangés ; seule la conversion est ajustée."
                }
              }
            }
          }
        },
        "id" : {
          "variations" : {
            "plural" : {
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld barang Anda saat ini dinilai terhadap %@. Kurs ini menyatakan kembali nilainya dalam %@. Harga yang semula dimasukkan tetap tidak berubah; hanya konversinya yang disesuaikan."
                }
              }
            }
          }
        },
        "ja" : {
          "variations" : {
            "plural" : {
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "現在、%1$lld 件の項目は %2$@ を基準として価格が設定されています。このレートにより、それらを %3$@ で表示し直します。当初入力された価格は変更されず、換算のみが調整されます。"
                }
              }
            }
          }
        },
        "ko" : {
          "variations" : {
            "plural" : {
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
