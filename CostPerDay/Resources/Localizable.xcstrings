    "The purchase price divided by the expected lifetime. This is the amount each day was budgeted to cost." : {
      "comment" : "Explanation of the 'Planned' cost basis",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Kaufpreis geteilt durch die erwartete Nutzungsdauer. Dies ist der Betrag, der je Tag eingeplant war."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The purchase price divided by the expected lifetime. This is the amount each day was budgeted to cost."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El precio de compra dividido entre la vida útil prevista. Es el importe que se presupuestó para cada día."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le prix d'achat divisé par la durée de vie prévue. Il s'agit du coût journalier initialement budgété."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Harga pembelian dibagi masa pakai yang diharapkan. Inilah biaya yang dianggarkan untuk setiap hari."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "購入価格を想定使用期間で割った金額です。1日あたりに予算として見込んだコストを示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "구매 가격을 예상 사용 기간으로 나눈 금액입니다. 하루에 지출하기로 계획한 금액을 의미합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O preço de compra dividido pela vida útil prevista. Este é o valor orçado para cada dia."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Цена покупки, делённая на ожидаемый срок службы. Это сумма, которая была запланирована на каждый день."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Giá mua chia cho tuổi thọ dự kiến. Đây là mức chi phí đã được dự trù cho mỗi ngày."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "购入价格除以预期使用年限，即每日预算应承担的金额。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "購入價格除以預期使用年限，即每日預算應負擔的金額。"
          }
        }
      }
    },
    "The purchase price divided by the number of days owned. This figure decreases for as long as the item is retained." : {
      "comment" : "Explanation of the 'To date' cost basis",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Kaufpreis geteilt durch die Anzahl der Besitztage. Dieser Wert sinkt, solange der Artikel behalten wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The purchase price divided by the number of days owned. This figure decreases for as long as the item is retained."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El precio de compra dividido entre el número de días en propiedad. Esta cifra disminuye mientras se conserve el artículo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le prix d'achat divisé par le nombre de jours de détention. Ce chiffre diminue tant que l'article est conservé."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Harga pembelian dibagi jumlah hari kepemilikan. Angka ini terus menurun selama barang tersebut masih dimiliki."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "購入価格を保有日数で割った金額です。使用を続けるかぎり、この金額は下がり続けます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "구매 가격을 보유 일수로 나눈 금액입니다. 항목을 계속 보유하는 동안 이 금액은 계속 낮아집니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O preço de compra dividido pelo número de dias de posse. Este valor diminui enquanto o item for mantido."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Цена покупки, делённая на число дней владения. Этот показатель снижается до тех пор, пока предмет остаётся у вас."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Giá mua chia cho số ngày đã sở hữu. Con số này tiếp tục giảm chừng nào món đồ còn được giữ lại."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "购入价格除以已持有天数。只要继续保留该物品，此数值便会持续下降。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "購入價格除以已持有天數。只要繼續保留該物品，此數值便會持續下降。"
          }
        }
      }
    },
    "The rate is fixed at the time of purchase, so this item's cost does not change with the market. All totals are shown in %@." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Kurs wird zum Kaufzeitpunkt festgeschrieben, sodass sich die Kosten dieses Artikels nicht mit dem Markt ändern. Alle Summen werden in %@ angezeigt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The rate is fixed at the time of purchase, so this item's cost does not change with the market. All totals are shown in %@."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tasa queda fijada en el momento de la compra, por lo que el costo de este artículo no varía con el mercado. Todos los totales se muestran en %@."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le taux est figé au moment de l'achat ; le coût de cet article ne varie donc pas avec le marché. Tous les totaux sont affichés en %@."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kurs ditetapkan pada saat pembelian, sehingga biaya barang ini tidak berubah mengikuti pasar. Seluruh total ditampilkan dalam %@."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "レートは購入時点で固定されるため、この項目のコストは市場の変動によって変わりません。合計はすべて %@ で表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "환율은 구매 시점에 고정되므로 이 항목의 비용은 시장 변동에 따라 달라지지 않습니다. 모든 합계는 %@(으)로 표시됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A taxa é fixada no momento da compra, portanto o custo deste item não varia com o mercado. Todos os totais são exibidos em %@."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Курс зафиксирован на момент покупки, поэтому стоимость этого предмета не зависит от рынка. Все итоги отображаются в %@."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
