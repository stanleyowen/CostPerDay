    "If no category matches, create your own with a dedicated icon and typical lifetime." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falls keine Kategorie passt, erstellen Sie eine eigene mit passendem Symbol und typischer Nutzungsdauer."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If no category matches, create your own with a dedicated icon and typical lifetime."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si ninguna categoría se ajusta, cree una propia con un icono específico y una vida útil habitual."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si aucune catégorie ne convient, créez la vôtre avec une icône dédiée et une durée de vie type."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika tidak ada kategori yang sesuai, buatlah kategori Anda sendiri dengan ikon dan masa pakai umum tersendiri."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "該当するカテゴリがない場合は、専用のアイコンと標準的な使用期間を設定した独自のカテゴリを作成してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "해당하는 카테고리가 없으면 전용 아이콘과 일반적인 사용 기간을 지정하여 직접 만들어 주세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se nenhuma categoria corresponder, crie a sua própria com um ícone específico e uma vida útil típica."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если ни одна категория не подходит, создайте собственную с отдельным значком и типичным сроком службы."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu không có danh mục nào phù hợp, hãy tạo danh mục riêng với biểu tượng và tuổi thọ thông thường của riêng nó."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若无合适的类别，可自行创建，并指定专属图标与典型使用年限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若無合適的類別，可自行建立，並指定專屬圖示與典型使用年限。"
          }
        }
      }
    },
